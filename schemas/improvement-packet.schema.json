{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frontofhouse.okii.uk/schemas/improvement-packet.schema.json",
  "title": "FOH Improvement Packet",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "source_type",
    "reason_code",
    "promotion_decision",
    "owner_subsystem",
    "routing",
    "ids",
    "evidence",
    "next_commands"
  ],
  "properties": {
    "schema_version": { "const": "foh_improvement_packet.v1" },
    "created_at": { "type": "string" },
    "source_type": {
      "type": "string",
      "enum": [
        "external_agent_run",
        "setup_failure",
        "proof_failure",
        "replay_failure",
        "knowledge_miss",
        "runtime_miss",
        "live_proof_failure"
      ]
    },
    "reason_code": { "type": "string", "minLength": 1 },
    "promotion_decision": {
      "type": "string",
      "enum": ["ignore", "fix_docs", "fix_config", "fix_cli", "fix_api", "fix_runtime", "add_test"]
    },
    "owner_subsystem": {
      "type": "string",
      "enum": ["docs", "cli", "api_contract", "runtime", "voice_contact", "dojo_certification", "infra_runner", "product_ux"]
    },
    "routing": {
      "type": "object",
      "required": ["owner_subsystem", "promotion_decision", "reason_family"],
      "properties": {
        "owner_subsystem": {
          "type": "string",
          "enum": ["docs", "cli", "api_contract", "runtime", "voice_contact", "dojo_certification", "infra_runner", "product_ux"]
        },
        "promotion_decision": {
          "type": "string",
          "enum": ["ignore", "fix_docs", "fix_config", "fix_cli", "fix_api", "fix_runtime", "add_test"]
        },
        "reason_family": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ids": {
      "type": "object",
      "properties": {
        "org_id": { "type": "string" },
        "agent_id": { "type": "string" },
        "conversation_id": { "type": "string" },
        "trace_id": { "type": "string" },
        "correlation_id": { "type": "string" },
        "proof_artifact": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["summary", "redaction"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "source_artifact_path": { "type": ["string", "null"] },
        "source_command": { "type": ["string", "null"] },
        "redaction": {
          "type": "object",
          "required": ["enabled", "fields"],
          "properties": {
            "enabled": { "const": true },
            "fields": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "redacted_source": {}
      },
      "additionalProperties": false
    },
    "next_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
